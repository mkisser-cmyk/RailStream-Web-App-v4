  const OPS = window.__RS_OPS;

  const fmtDur = (sec) => {
    sec = Math.max(0, Math.floor(sec||0));
    const d = Math.floor(sec/86400);
    const h = Math.floor((sec%86400)/3600);
    const m = Math.floor((sec%3600)/60);
    if (d>0) return `${d}d ${String(h).padStart(2,'0')}h`;
    if (h>0) return `${h}h ${String(m).padStart(2,'0')}m`;
    return `${m}m`;
  };

  const mk = (tag, cls, txt) => { const el=document.createElement(tag); if(cls) el.className=cls; if(txt!=null) el.textContent=txt; return el; };

  // ---- DVR range probing (cache 30s) ----
  const __rangeCache = window.__RS_DVR_RANGE_CACHE || (window.__RS_DVR_RANGE_CACHE = { ts:0, val:null });

  async function rsGetDvrRangeCached(){
    const now = Date.now();
    if (__rangeCache.val && (__rangeCache.ts + 30_000) > now) return __rangeCache.val;

    const nowUnix = await rsGetServerNowUnix();
    const urlFor = (off) => baseURL + `playlist_dvr_timeshift-${off}-${CHUNK_SEC}.m3u8${tokenParam()}`;

    // Find max valid offset (seconds) via exponential + binary search
    const step = CHUNK_SEC;
    let lo = 0;
    let hi = step;

    // If even offset=0 fails, treat as no DVR
    const ok0 = await playlistOK(urlFor(0));
    if (!ok0){
      const val = { nowUnix, maxOffset: 0, oldestUnix: nowUnix, newestUnix: nowUnix, availableSec: 0 };
      __rangeCache.val = val; __rangeCache.ts = Date.now();
      return val;
    }

    // Exponential search up to MAX_WINDOW_SEC
    while (hi < MAX_WINDOW_SEC){
      hi = Math.min(MAX_WINDOW_SEC, hi);
      hi = Math.floor(hi/step)*step;
      if (hi <= lo) break;
      const ok = await playlistOK(urlFor(hi));
      if (ok){ lo = hi; hi = hi*2; }
      else { break; }
    }
    hi = Math.min(MAX_WINDOW_SEC, hi);
    hi = Math.floor(hi/step)*step;
    if (hi <= lo) hi = lo + step;

    // Binary search between lo..hi (lo ok, hi maybe not)
    let left = lo, right = Math.min(MAX_WINDOW_SEC, hi);
    right = Math.floor(right/step)*step;
    while (right - left > step){
      const mid = Math.floor(((left + right)/2)/step)*step;
      if (mid <= left) break;
      const ok = await playlistOK(urlFor(mid));
      if (ok) left = mid; else right = mid;
    }

    const maxOffset = left;
    const availableSec = Math.min(MAX_WINDOW_SEC, maxOffset + step);
    const oldestUnix = nowUnix - availableSec;
    const newestUnix = nowUnix;

    const val = { nowUnix, maxOffset, oldestUnix, newestUnix, availableSec };
    __rangeCache.val = val; __rangeCache.ts = Date.now();
    OPS.lastRange = val;
    return val;
  }

  // ---- UI elements ----
  const row = mk('div','rs-ops-row');
  const title = mk('span','rs-ops-title');
  title.innerHTML = `<span class="rs-brand">RAILCENTER</span> | <span id="rs-ops-mode">${OPS.mode === 'live' ? 'Live Ops' : 'Review Ops'}</span>`;
  const timeline = mk('span','rs-ops-meta rs-ops-small','Total Timeline: …');
  timeline.id = 'rs-ops-timeline';
  row.appendChild(title);
  row.appendChild(timeline);

  const livePill = mk('button','rs-ops-pill', 'Live Ops');
  const reviewPill = mk('button','rs-ops-pill', 'Review Ops');
  const syncPills = ()=>{
    livePill.classList.toggle('rs-on', OPS.mode === 'live');
    reviewPill.classList.toggle('rs-on', OPS.mode === 'review');
    try{
      const m = document.getElementById('rs-ops-mode');
      if (m) m.textContent = (OPS.mode === 'live' ? 'Live Ops' : 'Review Ops');
      else title.innerHTML = `<span class="rs-brand">RAILCENTER</span> | <span id="rs-ops-mode">${OPS.mode === 'live' ? 'Live Ops' : 'Review Ops'}</span>`;
    }catch(_){
      title.textContent = `RAILCENTER | ${OPS.mode === 'live' ? 'Live Ops' : 'Review Ops'}`;
    }
  };
  syncPills();

  row.appendChild(livePill);
  row.appendChild(reviewPill);

  // Review controls (only visible in Review Ops)
  const prevBtn = mk('button','rs-ops-btn','⟵ Prev Block');
  const nextBtn = mk('button','rs-ops-btn','Next Block ⟶');
  const blockBtn = mk('button','rs-ops-btn', `Block: ${Math.round(OPS.blockSec/60)}m`);
  const reviewCtl = mk('div','rs-ops-row');
  reviewCtl.appendChild(prevBtn);
  reviewCtl.appendChild(nextBtn);
  reviewCtl.appendChild(blockBtn);

  // Mount
  host.appendChild(row);
  host.appendChild(reviewCtl);

  const syncReviewCtl = ()=>{
    reviewCtl.style.display = (OPS.mode === 'review') ? 'flex' : 'none';
    const mins = OPS.blockSec >= 3600 ? `${OPS.blockSec/3600}h` : `${OPS.blockSec/60}m`;
    blockBtn.textContent = `Block: ${mins}`;
  };
  syncReviewCtl();

  async function refreshTimeline(){
    try{
      const r = await rsGetDvrRangeCached();
      const txt = (r.availableSec > 0) ? `Total Timeline: ${fmtDur(r.availableSec)}` : `Total Timeline: 0m`;
      timeline.textContent = txt;
    }catch(_){
      timeline.textContent = 'Total Timeline: …';
    }
  }
  refreshTimeline();

  // ---- Overlay / setup ----
  function closeOverlay(){
    const ex = document.getElementById('rs-ops-overlay');
    if (ex) ex.remove();
  }

  function dayLabelFor(dayIdx){
    // Show actual date in site-local when possible, otherwise relative
    try{
      const nowMs = Date.now();
      const ms = nowMs - (dayIdx * 86400 * 1000);
      const tz = SITE_TZ || undefined;
      const fmt = new Intl.DateTimeFormat('en-US', { timeZone: tz, weekday:'short', month:'2-digit', day:'2-digit' });
      const d = fmt.format(new Date(ms));
      if (dayIdx === 0) return `Today (${d})`;
      if (dayIdx === 1) return `Yesterday (${d})`;
      return `${dayIdx} days ago (${d})`;
    }catch(_){
      if (dayIdx === 0) return 'Today';
      if (dayIdx === 1) return 'Yesterday';
      return `${dayIdx} days ago`;
    }
  }

  async function openReviewSetup(){
    closeOverlay();

    const r = await rsGetDvrRangeCached();
    const availDays = Math.max(0, Math.min(30, Math.floor(r.availableSec / 86400))); // cap UI list
    const overlay = mk('div','rs-ops-overlay');
    overlay.id = 'rs-ops-overlay';

