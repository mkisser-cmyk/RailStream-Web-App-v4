      window.__rsToastHide = setTimeout(()=>{ t.style.opacity='0'; setTimeout(()=>{ t.style.display='none'; }, 200); }, 2200);
    }catch(_){}
  }

  function isDvr(){ return (currentDvrOffset|0) > 0; }
  function goLive(){ try{ resetToolbarToLiveUI(); setChunk(0); toast('Time not available — jumped to Live'); }catch(_){ setChunk(0); } }

  player.on('error', async ()=>{
    if (!isDvr()) {
      await __rsRotateToken('error');
      return;
    }
    goLive();
  });

  let badTicks = 0;
  setInterval(()=>{
    try{
      if (!isDvr()) { badTicks = 0; return; }
      const v = player.tech_ && player.tech_.el ? player.tech_.el() : document.querySelector('video');
      if (!v) return;
      const ct = v.currentTime || 0;
      const b = v.buffered; const ahead = (b && b.length) ? (b.end(b.length-1) - ct) : 0;
      const stuck = (v.readyState <= 2) || (ahead < 0.25);
      badTicks = stuck ? (badTicks + 1) : 0;
      if (badTicks >= 16){
        badTicks = 0;
        goLive();
      }
    }catch(_){}
  }, 500);
})();

