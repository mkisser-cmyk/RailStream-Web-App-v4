    bWrap.appendChild(steps);
    panel.appendChild(bWrap);

    const foot = mk('div','rs-ops-small rs-ops-muted', `Total Timeline: ${fmtDur(r.availableSec)}${(r.availableSec < MAX_WINDOW_SEC ? ' (building)' : '')}`);
    panel.appendChild(foot);

    const actions = mk('div','rs-ops-actions');
    const cancel = mk('button','rs-ops-btn','Cancel'); cancel.type='button';
    const goLive = mk('button','rs-ops-btn','Back to Live Ops'); goLive.type='button';
