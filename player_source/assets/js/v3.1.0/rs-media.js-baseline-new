// ---- Helpers for safe seeking & absolute time ----
function __rsCurrentUnixFromTime(t){
  try{
    const sk = player.seekable(); if (!sk || !sk.length) return null;
    const end = sk.end(0);
    const nowU = Math.floor(Date.now()/1000);
    const cur = (typeof t==='number' ? t : player.currentTime());
    const secondsFromEnd = Math.max(0, end - cur);
    const unix = nowU - currentDvrOffset - secondsFromEnd;
    return Math.floor(unix);
  }catch(_){ return null; }
}

// --- easing helper for in-window seeks (no await required) ---
function __rsEaseTo(targetTime, durationMs = 180){
  try{
    const start = Number(player.currentTime()) || 0;
    const dist  = targetTime - start;
    const t0    = performance.now();
    (function step(now){
      const p = Math.min(1, (now - t0) / durationMs);
      const w = p*p*(3 - 2*p); // smoothstep
      try { player.currentTime(start + dist*w); } catch(_){}
      if (p < 1) requestAnimationFrame(step);
    })(t0);
  }catch(_){}
}

async function __rsSeekBy(deltaSeconds){
  try{
    const sk = player.seekable(); if (!sk || !sk.length) return;
    const start = sk.start(0), end = sk.end(0);
    const cur = player.currentTime();
    let target = cur + deltaSeconds;
    // If inside current seekable, ease instead of hard jump
    if (target >= start && target <= end){
      target = Math.max(start, Math.min(end, target));
      __rsEaseTo(target);
      return;
    }
    // Otherwise map to absolute unix and use existing jumpToUnix
    const curU = __rsCurrentUnixFromTime(cur);
    if (curU == null) return;
    const targetUnix = curU + Math.round(deltaSeconds);
    await jumpToUnix(targetUnix, false);
  }catch(_){}
}

const pad = n => String(n).padStart(2, '0');// ---- Site-local (camera) time support ----
// If RS_CONFIG.siteTz is set (IANA TZ like "America/Chicago"), the DVR toolbar interprets HH:MM as SITE LOCAL time.
// This keeps what the user selects aligned with what the camera overlay clock shows, regardless of the viewer PC timezone.
const SITE_TZ = (C.siteTz && String(C.siteTz).trim()) || null;

const __rsTzFmtCache = new Map();
function __rsTzFmt(tz){
  if (!tz) return null;
  if (__rsTzFmtCache.has(tz)) return __rsTzFmtCache.get(tz);
  const fmt = new Intl.DateTimeFormat('en-US', {
    timeZone: tz,
    year: 'numeric', month: '2-digit', day: '2-digit',
    hour: '2-digit', minute: '2-digit', second: '2-digit',
    hour12: false
  });
  __rsTzFmtCache.set(tz, fmt);
  return fmt;
}

function __rsTzParts(tz, utcMs){
  const fmt = __rsTzFmt(tz);
  if (!fmt) return null;
  const parts = fmt.formatToParts(new Date(utcMs));
  const get = (t) => Number((parts.find(p => p.type === t) || {}).value || 0);
  return {
    y: get('year'),
    mo: get('month'),
    d: get('day'),
    h: get('hour'),
    mi: get('minute'),
    s: get('second')
  };
}

// Offset in minutes of tz at utcMs. Positive means tz is ahead of UTC.
function __rsTzOffsetMin(tz, utcMs){
  const p = __rsTzParts(tz, utcMs);
  if (!p) return 0;
  const asUtc = Date.UTC(p.y, p.mo - 1, p.d, p.h, p.mi, p.s);
  return (asUtc - utcMs) / 60000;
}

// Convert a site-local Y-M-D HH:MM to unix seconds (UTC) for the given tz.
function __rsSiteLocalToUnix(tz, y, mo, d, hh, mm){
  // Initial guess: interpret as UTC; then subtract tz offset.
  let guess = Date.UTC(y, mo - 1, d, hh, mm, 0);
  let off = __rsTzOffsetMin(tz, guess);
  let utc = guess - off * 60000;
  // Re-evaluate once (DST edges)
  off = __rsTzOffsetMin(tz, utc);
  utc = guess - off * 60000;
  return Math.floor(utc / 1000);
}

// Derive the site-local calendar date for "now - dayIdx" using the SERVER clock (cached).
async function __rsSiteDateForDayIdx(dayIdx){
  const nowUnix = await rsGetServerNowUnix();
  const nowMs = nowUnix * 1000;

  // Get site-local Y/M/D for now
  const nowP = __rsTzParts(SITE_TZ, nowMs);
  if (!nowP) return null;

  // Use noon to avoid DST midnight weirdness when stepping days
  const noonGuess = Date.UTC(nowP.y, nowP.mo - 1, nowP.d, 12, 0, 0);
  const noonUtc = noonGuess - (__rsTzOffsetMin(SITE_TZ, noonGuess) * 60000);
  const targetUtc = noonUtc - (dayIdx * 86400 * 1000);

  // Re-extract the site-local date parts for the target day
  const tp = __rsTzParts(SITE_TZ, targetUtc);
  return tp ? { y: tp.y, mo: tp.mo, d: tp.d } : null;
}

async function unixFromSiteDayAndTime(dayIdx, hh24, mm){
  const date = await __rsSiteDateForDayIdx(dayIdx);
  if (!date) return null;
  let u = __rsSiteLocalToUnix(SITE_TZ, date.y, date.mo, date.d, hh24, mm);

  // Clamp using server time (not viewer PC time)
  const nowU = await rsGetServerNowUnix();
  if (u > nowU) u = nowU;
  if (nowU - u > MAX_WINDOW_SEC) u = nowU - MAX_WINDOW_SEC + 5;
  return u;
}

// Unified: interpret toolbar time as site local if configured, otherwise viewer local.
async function unixFromUiDayAndTime(dayIdx, hh24, mm){
  if (SITE_TZ){
    const u = await unixFromSiteDayAndTime(dayIdx, hh24, mm);
    if (typeof u === 'number' && Number.isFinite(u)) return u;
  }
  return unixFromLocalDayAndTime(dayIdx, hh24, mm);
}

// For default HH:MM in the toolbar, prefer site-local *display* time (best-effort, uses local clock for ms).
function __rsUiNowHHMM(){
  if (!SITE_TZ) return null;
  const p = __rsTzParts(SITE_TZ, Date.now());
  if (!p) return null;
  return { h: p.h, m: p.mi };
}

function unixFromLocalDayAndTime(dayIdx, hh24, mm){
  const now = new Date();
  const t = new Date(now);
  t.setDate(now.getDate() - dayIdx);
  t.setHours(hh24, mm, 0, 0);
  let u = Math.floor(t.getTime()/1000);
  const nowU = Math.floor(now.getTime()/1000);
  if (u > nowU) u = nowU;
  if (nowU - u > MAX_WINDOW_SEC) u = nowU - MAX_WINDOW_SEC + 5;
  return u;
}

function dayBlockToOffset(dayIdx, blockIdx){
  return Math.max(0, Math.min(MAX_WINDOW_SEC - CHUNK_SEC, (dayIdx*24 + blockIdx*CHUNK_HOURS) * 3600));
}

function offsetToDayBlock(offset){
  const hours = Math.floor(offset/3600);
  return { day: Math.floor(hours/24), block: Math.floor((hours % 24) / CHUNK_HOURS) };
}

async function headOK(url){
  const ac = new AbortController(); const t = setTimeout(()=>ac.abort(), 2000);
  try{
    const r = await fetch(url, {method:'HEAD', cache:'no-store', signal:ac.signal});
    clearTimeout(t);
    return r.ok;
  }catch(e){ clearTimeout(t); return false; }
}

// Stronger than HEAD for DVR probing: verify the URL returns a real M3U8 playlist.
// This prevents "false positives" when the server responds 200 with an error page or empty body.
async function playlistOK(url){
  const ac = new AbortController();
  const t = setTimeout(()=>ac.abort(), 2500);
  try{
    const r = await fetch(url, {
      method:'GET',
      cache:'no-store',
      signal:ac.signal,
      headers: { 'Range': 'bytes=0-4096' }
    });
    clearTimeout(t);
    if (!r || !r.ok) return false;
    const ct = (r.headers && r.headers.get) ? (r.headers.get('content-type') || '') : '';
    // Some servers send text/plain; accept as long as the body looks like M3U8.
    const txt = (await r.text()).trim();
    if (!txt.startsWith('#EXTM3U')) return false;
    // Accept either media playlist segments or master playlist variants.
    if (txt.includes('#EXTINF') || txt.includes('#EXT-X-STREAM-INF')) return true;
    // Occasionally Nimble returns only headers at the start; accept if it at least looks like HLS.
    if (txt.includes('#EXT-X-TARGETDURATION') || txt.includes('#EXT-X-MEDIA-SEQUENCE')) return true;
    return false;
  }catch(e){
    clearTimeout(t);
    return false;
  }
}

// Cached server time helper: HEAD to a same-origin lightweight URL and read Date header
// Caches result for 30 seconds and falls back to local clock when unavailable
const __rsServerTimeCache = { ts: 0, unix: null };
async function rsGetServerNowUnix(){
  try{
    const now = Date.now();
    if ((__rsServerTimeCache.ts || 0) + 30_000 > now && Number.isFinite(__rsServerTimeCache.unix)){
      return __rsServerTimeCache.unix;
    }

    // Choose a lightweight same-origin URL; prefer the baseURL root if it looks same-origin
    let probe = '/';
    try{
      if (typeof baseURL === 'string'){
        const u = new URL(baseURL, window.location.origin);
        if (u.origin === window.location.origin) probe = u.pathname || '/';
      }
    }catch(_){ probe = '/'; }

    const ac = new AbortController(); const to = setTimeout(()=>ac.abort(), 2000);
    try{
      const r = await fetch(probe, { method: 'HEAD', cache: 'no-store', signal: ac.signal });
      clearTimeout(to);
      const date = r && r.headers ? r.headers.get('date') : null;
      if (date){
        const s = Date.parse(date);
        if (Number.isFinite(s)){
          const u = Math.floor(s / 1000);
          __rsServerTimeCache.unix = u;
          __rsServerTimeCache.ts = Date.now();
          return u;
        }
      }
    }catch(_){ clearTimeout(to); }

    // fallback to local time
    const fu = Math.floor(Date.now()/1000);
    __rsServerTimeCache.unix = fu;
    __rsServerTimeCache.ts = Date.now();
    return fu;
  }catch(_){ return Math.floor(Date.now()/1000); }
}

