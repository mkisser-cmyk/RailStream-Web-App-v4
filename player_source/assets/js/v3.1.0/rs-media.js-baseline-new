const RS_RESUME_KEY = 'rs:lastPoint:v1';

function __rsSaveResumePoint(){
  try{
    const sk = player.seekable(); if (!sk || !sk.length) return;
    const end = sk.end(0);
    const nowU = Math.floor(Date.now()/1000);
    const secondsBehindEnd = Math.max(0, end - player.currentTime());
    const wallUnix = nowU - currentDvrOffset - secondsBehindEnd;
    localStorage.setItem(RS_RESUME_KEY, JSON.stringify({
      cam: camName,
      wallUnix: Math.floor(wallUnix),
      savedAt: nowU,
      v: (window.RS_VERSION || 'DEV')
    }));
  }catch(_){}
}

function __rsReadResumePoint(){
  try{ return JSON.parse(localStorage.getItem(RS_RESUME_KEY) || 'null'); }catch(_){ return null; }
}

