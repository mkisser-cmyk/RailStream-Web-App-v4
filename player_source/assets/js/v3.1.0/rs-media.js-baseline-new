// ===== token URL builder (iframe-safe; cross-origin only when explicitly configured) =====
// Config:
//   RS_CONFIG.tokenUrl                (required to enable refresh)
//   RS_CONFIG.tokenAllowCrossOrigin   (optional, default false)
//   RS_CONFIG.tokenCredentials        ('same-origin' | 'include' | 'omit') optional
function __rsTokenUrl(reason) {
  // If tokenUrl is not explicitly provided, DO NOT attempt refresh.
  if (!C.tokenUrl) return null;

  // Resolve relative URL against the iframe document origin
  const u = new URL(C.tokenUrl, window.location.origin);

  // Default: same-origin only (safe)
  const allowX = !!C.tokenAllowCrossOrigin;
  if (!allowX && u.origin !== window.location.origin) return null;

  if (camName) u.searchParams.set('cam', camName);
  if (reason)  u.searchParams.set('reason', reason);
  return u.toString();
}

// safeSeekUnix: snap to DVR bounds, call jumpToUnix, retry once if seek appears stalled
async function safeSeekUnix(targetUnix){
  try{
    const nowUnix = await rsGetServerNowUnix();
    const elapsed = nowUnix - targetUnix;
    if (elapsed < 0 || elapsed > MAX_WINDOW_SEC){ setChunk(0); return; }

    await jumpToUnix(targetUnix, true);

    // wait a short period for loadedmetadata/seek to take effect
    await new Promise(res => setTimeout(res, 2200));

    try{
      const sk = player.seekable();
      if (sk && sk.length){
        const end = sk.end(0);
        const offset = (typeof player.__rsCurrentOffset === 'number') ? player.__rsCurrentOffset : currentDvrOffset || 0;
        const nowMinusOffset = nowUnix - offset;
        const secondsBehindEnd = nowMinusOffset - targetUnix;
        const expected = Math.max(0, end - secondsBehindEnd);
        const cur = Number(player.currentTime() || 0);
        if (Math.abs(cur - expected) > 4){
          // retry once
          await jumpToUnix(targetUnix, true);
        }
      } else {
        // no seekable yet — retry once
        await jumpToUnix(targetUnix, true);
      }
    }catch(_){ /* swallow */ }
  }catch(_){ /* swallow */ }
}

function __rsTokenCredentialsFor(urlStr){
  try{
    if (C.tokenCredentials) return String(C.tokenCredentials);
    const u = new URL(urlStr, window.location.origin);
    // Same origin: keep cookies
    if (u.origin === window.location.origin) return 'same-origin';
    // Cross origin: default omit unless user explicitly wants include
    return 'omit';
  }catch(_){
    return 'same-origin';
  }
}

function tokenParam() {
  return currentToken ? `?wmsAuthSign=${encodeURIComponent(currentToken)}` : "";
}

// Ask the server for a fresh token. No-op unless tokenUrl is configured.
async function __rsRefreshTokenIfNeeded(reason) {
  const url = __rsTokenUrl(reason || 'timer');
  if (!url) return null;

  try {
    const ac = new AbortController();
    const to = setTimeout(() => ac.abort(), 4000);

    const r = await fetch(url, {
      method: 'GET',
      cache: 'no-store',
      signal: ac.signal,
      credentials: __rsTokenCredentialsFor(url),
      headers: { 'Accept': 'application/json' }
    });

    clearTimeout(to);
    if (!r.ok) return null;

    const data = await r.json().catch(() => null);
    if (!data || !data.token) return null;

    const t = String(data.token).trim();
    if (!t) return null;

    return { token: t };
  } catch (_) {
    return null;
  }
}

// Safely rotate the token + reattach stream without losing position
let __rsTokenRotateInFlight = false;
async function __rsRotateToken(reason) {
  if (__rsTokenRotateInFlight) return;
  __rsTokenRotateInFlight = true;

  try {
    // If refresh isn’t configured, do nothing (don’t break playback)
    if (!C.tokenUrl) return;

    const snapUnix = __rsCurrentUnixFromTime();
    const res = await __rsRefreshTokenIfNeeded(reason || 'timer');
    if (!res || !res.token) return;
    if (res.token === currentToken) return;

    currentToken = res.token;

    // If we know where we are in wall time, keep that position
    if (snapUnix != null) {
      await jumpToUnix(snapUnix, false);
    } else {
      // Otherwise just reload current window (live or DVR)
      await setChunk(currentDvrOffset || 0, { autoplay: true });
    }
  } catch (_) {
    // silent by design
  } finally {
    __rsTokenRotateInFlight = false;
  }
}

