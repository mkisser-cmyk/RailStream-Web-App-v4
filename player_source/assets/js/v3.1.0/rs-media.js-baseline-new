/* ====== Stream window switching ====== */

/**
 * setChunk(offset, opts)
 *  - offset: DVR timeshift offset in seconds
 *  - opts.autoplay: whether to attempt playback after load (default true)
 */
async function setChunk(offset, opts = {}) {
  const { autoplay = true, windowSec = null } = opts;

  // Request a playlist window that matches Review Ops "Block" size when possible.
  // If the server doesn't serve that duration, we fall back to CHUNK_SEC.
  let win = Number(windowSec);
  if (!Number.isFinite(win) || win <= 0) win = __rsDesiredWindowSec();
  win = Math.max(900, Math.min(MAX_WINDOW_SEC, Math.floor(win)));

  // Align offset to the requested window size.
  let off = Math.max(0, Math.floor(Number(offset || 0) / win) * win);

  const makeUrl = (o, w) => baseURL + `playlist_dvr_timeshift-${o}-${w}.m3u8${tokenParam()}`;
  let url      = makeUrl(off, win);
  let fallback = makeUrl(0, win);

  let ok = await playlistOK(url);
  if (!ok && win !== CHUNK_SEC){
    // Transparent fallback to default window size
    win = CHUNK_SEC;
    off = Math.max(0, Math.floor(Number(offset || 0) / win) * win);
    url = makeUrl(off, win);
    fallback = makeUrl(0, win);
    ok = await playlistOK(url);
  }

  const srcUrl = ok ? url : fallback;

  currentDvrOffset = off;
  try{ player.__rsCurrentOffset = off; }catch(_){ }
  try{ player.__rsCurrentWindowSec = win; }catch(_){ }

  player.src({ type: 'application/x-mpegURL', src: srcUrl });
  player.load();

  if (!autoplay) return;

  const startPlayback = () => {
    // For live (offset 0), intentionally sit a bit behind the edge so we build a bigger buffer
    if (offset === 0 && LIVE_LAG_SEC > 0) {
      try {
        const sk = player.seekable();
        if (sk && sk.length) {
          const start = sk.start(0);
          const end   = sk.end(0);
          const t     = Math.max(start, end - LIVE_LAG_SEC);
          player.currentTime(t);
        }
      } catch (_) {}
    }

    const p = player.play();
    if (p && p.catch) p.catch(()=>{ /* autoplay blocked; user can click play */ });
  };

  // Always wait for metadata before starting, to avoid bufferStalled on startup
  player.one('loadedmetadata', startPlayback);
}

async function jumpToUnix(targetUnix, updateUrl){
  try{ __rsSyncSelectorsToUnix(targetUnix); }catch(_){ }

  const nowUnix = await rsGetServerNowUnix();
  const elapsed = nowUnix - targetUnix;

  if (elapsed < 0 || elapsed > MAX_WINDOW_SEC){ 
    setChunk(0); 
    return; 
  }

  const desiredWin = __rsDesiredWindowSec();
  const offset = Math.floor(elapsed/desiredWin) * desiredWin;

  const curWin = (typeof player.__rsCurrentWindowSec === 'number' && player.__rsCurrentWindowSec > 0)
    ? player.__rsCurrentWindowSec
    : CHUNK_SEC;
  const sameChunk = (typeof player.__rsCurrentOffset === 'number')
    && (player.__rsCurrentOffset === offset)
    && (curWin === desiredWin);

  // Only reload playlist if the desired chunk differs from what's currently attached
  if (sameChunk){
    // Seek within current playlist if possible; otherwise wait for metadata
    try{
      const sk = player.seekable();
      if (sk && sk.length){
        const seekEnd = sk.end(0);
        const off = (typeof currentDvrOffset === 'number') ? currentDvrOffset : offset;
        const nowMinusOffset = nowUnix - off;
        const secondsBehindEnd = nowMinusOffset - targetUnix;
        const t = Math.max(0, seekEnd - secondsBehindEnd);
        try{ player.currentTime(t); }catch(_){ }
        const p = player.play(); if (p && p.catch) p.catch(()=>{});
      } else {
        player.one('loadedmetadata', ()=>{
          try{
            const sk2 = player.seekable(); if (!sk2 || !sk2.length) return;
            const seekEnd = sk2.end(0);
            const off = (typeof currentDvrOffset === 'number') ? currentDvrOffset : offset;
            const nowMinusOffset = nowUnix - off;
            const secondsBehindEnd = nowMinusOffset - targetUnix;
            const t = Math.max(0, seekEnd - secondsBehindEnd);
            try{ player.currentTime(t); }catch(_){}
            const p = player.play(); if (p && p.catch) p.catch(()=>{});
          }catch(_){ }
        });
      }
    }catch(_){
      // If anything goes wrong, fall back to reloading the chunk
      await setChunk(offset, { autoplay: false, windowSec: desiredWin });
      player.one('loadedmetadata', ()=>{
        try{
          const sk = player.seekable(); if (!sk || !sk.length) return;
          const seekEnd = sk.end(0);
          const off = (typeof currentDvrOffset === 'number') ? currentDvrOffset : offset;
          const nowMinusOffset = nowUnix - off;
          const secondsBehindEnd = nowMinusOffset - targetUnix;
          const t = Math.max(0, seekEnd - secondsBehindEnd);
          try{ player.currentTime(t); }catch(_){ }
          const p = player.play(); if (p && p.catch) p.catch(()=>{});
        }catch(_){ }
      });
    }
  } else {
    await setChunk(offset, { autoplay: false, windowSec: desiredWin });
    // After loading the new chunk, position to the requested wall time
    player.one('loadedmetadata', ()=>{
      try{
        const sk = player.seekable(); if (!sk || !sk.length) return;
        const seekEnd = sk.end(0);
        const off = (typeof currentDvrOffset === 'number') ? currentDvrOffset : offset;
        const nowMinusOffset = nowUnix - off;
        const secondsBehindEnd = nowMinusOffset - targetUnix;
        const t = Math.max(0, seekEnd - secondsBehindEnd);
        try{ player.currentTime(t); }catch(_){ }
        const p = player.play(); if (p && p.catch) p.catch(()=>{});
      }catch(_){ }
    });
  }

  if (updateUrl){
    const url = new URL(window.location.href);
    url.searchParams.set('t', String(targetUnix));
    url.searchParams.set('cam', camName);
    url.searchParams.set('dev', C.dev ? '1' : '0');
    history.replaceState({}, '', url.toString());
  }
}

/* ====== Hover thumbnails (timeline only; no tab-switch fadeouts) ====== */
(function setupHoverThumbs(){
  const preview = document.getElementById('thumb-preview');
  if (!preview) return;

  try{
    preview.style.border = "2px solid #ff6600";
    preview.style.borderRadius = "6px";
    preview.style.boxShadow = "0 0 6px rgba(255,102,0,0.5)";
  }catch(_){}

  const NO_THUMB_URL = '/video/img/no-preview.jpeg';
  let overBar = false;
  let lastStamp = 0;
  let raf = 0;

  const control = player.controlBar && player.controlBar.progressControl
    ? player.controlBar.progressControl.el()
    : null;
  if (!control) return;

  function evenCandidates(unix){
    const baseEven = Math.floor(unix/2)*2;
    const deltas = [0,-2,-4,-6,-8,-10,2,4,6,8,10];
    const set = new Set(); deltas.forEach(d=>set.add(baseEven+d));
    return Array.from(set);
  }
  function tryLoad(urls, done){
    if (!urls.length) return done(null);
    const u = urls.shift();
    const im = new Image();
    let finished = false;
    const t = setTimeout(()=>{ if(!finished){ finished=true; tryLoad(urls, done); } }, 1200);
    im.onload = async()=>{ if(finished) return; clearTimeout(t); finished=true; try{ await im.decode(); }catch(_){} done(u); };
    im.onerror= ()=>{ if(finished) return; clearTimeout(t); finished=true; tryLoad(urls, done); };
    im.src = u;
  }
  function show(){ preview.style.display='block'; preview.style.opacity='1'; }
  function hide(){ preview.style.opacity='0'; setTimeout(()=>{ if (!overBar) preview.style.display='none'; }, 180); }

  function tick(xClient){
    raf = 0;
    if (!overBar) return;

    const rect = control.getBoundingClientRect();
    const pct = Math.max(0, Math.min(1, (xClient - rect.left) / rect.width));
    const sk = player.seekable(); if (!sk || !sk.length) return;

    const s0 = sk.start(0), s1 = sk.end(0);
    const hover = s0 + pct*(s1 - s0);

    const nowU = Math.floor(Date.now()/1000);
    const unix = Math.floor(nowU - currentDvrOffset - (s1 - hover));
    const stamp = unix - (unix % 2);

    const vrect = player.el().getBoundingClientRect();
    const boxW = preview.offsetWidth || 205;
    let left = xClient - vrect.left;
    left = Math.max(20 + boxW/2, Math.min(left, player.el().offsetWidth - 20 - boxW/2));
    preview.style.left = `${left}px`;

    show();

    if (stamp === lastStamp) return;
    lastStamp = stamp;

    const skew = (typeof window.RS_THUMB_SKEW === 'number') ? window.RS_THUMB_SKEW : 16;
    const adj = stamp - skew;
    const candidates = evenCandidates(adj).map(t => `${thumbBase}${t}.jpg`);

    tryLoad([...candidates], (found)=>{
      if (!overBar || stamp !== lastStamp) return; // stale
      if (found){
        preview.style.backgroundImage = `url('${found}')`;
      } else {
        preview.style.backgroundImage = `url('${NO_THUMB_URL}')`;
      }
      show();
    });
  }

  control.addEventListener('mouseenter', ()=>{ overBar = true; show(); });
  control.addEventListener('mouseleave', ()=>{ overBar = false; hide(); });

  control.addEventListener('mousemove', (e)=>{
    if (!overBar) return;
    if (!raf) raf = requestAnimationFrame(()=> tick(e.clientX));
  });
  control.addEventListener('touchmove', (e)=>{
    const t = e.touches && e.touches[0]; if (!t) return;
    overBar = true;
    if (!raf) raf = requestAnimationFrame(()=> tick(t.clientX));
  }, {passive:true});
  control.addEventListener('touchstart', ()=>{ overBar = true; show(); }, {passive:true});
  control.addEventListener('touchend',   ()=>{ overBar = false; hide();   }, {passive:true});
})();

/* ====== Init helpers ====== */
function __rsWallStrFromSnapshot(snap){
  try{
    const ts = (snap && (snap.wallUnix || snap.nowUnix)) ? (snap.wallUnix || snap.nowUnix) : (Date.now()/1000);
    const d = new Date(ts*1000);
    const hh = String(d.getHours()).padStart(2,'0');
    const mm = String(d.getMinutes()).padStart(2,'0');
    const ss = String(d.getSeconds()).padStart(2,'0');
    const MO = String(d.getMonth()+1).padStart(2,'0');
    const DD = String(d.getDate()).toString().padStart(2,'0');
    return `${hh}:${mm}:${ss} ${MO}/${DD}`;
  }catch(_){ return 'n/a'; }
}

function __rsWallStrNow(){
  try{
    const sk = player && player.seekable && player.seekable();
    if (!sk || !sk.length) return 'n/a';
    const end = sk.end(0);
    const ct  = (player && typeof player.currentTime==='function') ? player.currentTime() : 0;
    const nowU = (typeof window.nowUnix==='number' && window.nowUnix>0) ? window.nowUnix : Math.floor(Date.now()/1000);
    const ts = nowU - (typeof currentDvrOffset==='number'? currentDvrOffset:0) - (end - ct);
    const d = new Date(ts*1000);
    const hh = String(d.getHours()).padStart(2,'0');
    const mm = String(d.getMinutes()).padStart(2,'0');
    const ss = String(d.getSeconds()).padStart(2,'0');
    const MO = String(d.getMonth()+1).padStart(2,'0');
    const DD = String(d.getDate()).toString().padStart(2,'0');
    return `${hh}:${mm}:${ss} ${MO}/${DD}`;
  }catch(_){ return 'n/a'; }
}

function __rsLatencySeconds(){
  try{
    if (!(player && typeof player.currentTime==='function' && player.seekable)) return 'n/a';
    const sk = player.seekable();
    if (!sk || !sk.length) return 'n/a';
    const start = sk.start(0);
    const end   = sk.end(0);
    const ct    = player.currentTime();
    const win   = Math.max(0, end - start);

    let latencyA = end - ct;
    let latencyB = end - (start + ct);

    const clamp = (x)=> Math.max(0, Math.min(win, x));
    latencyA = clamp(latencyA);
    latencyB = clamp(latencyB);

    let d = Math.min(latencyA, latencyB);
    if (latencyA === 0 && latencyB > 0) d = latencyB;
    if (latencyB === 0 && latencyA > 0) d = latencyA;

    return d.toFixed(2) + ' s';
  }catch(_){ return 'n/a'; }
}

