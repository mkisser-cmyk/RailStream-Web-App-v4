    // Block sizes
    const bWrap = mk('div','rs-ops-field');
    bWrap.appendChild(mk('label', null, 'Block size'));
    const steps = mk('div','rs-ops-steps');
    const sizes = [
      ['15m', 15*60], ['30m', 30*60], ['1h', 60*60], ['2h', 2*60*60], ['4h', 4*60*60],
      ['8h', 8*60*60], ['12h', 12*60*60], ['16h', 16*60*60], ['24h', 24*60*60]
    ];
    let selected = OPS.blockSec || 3600;
    const syncFns = [];
    for (const [labelTxt, sec] of sizes){
      const b = mk('button','rs-ops-step', labelTxt);
      b.type='button';
      const sync = ()=> b.classList.toggle('rs-on', selected === sec);
      b.onclick = ()=>{ selected = sec; syncFns.forEach(fn=>fn()); };
      syncFns.push(sync);
