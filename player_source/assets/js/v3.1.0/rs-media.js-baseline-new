// --- Resume-at-pause fix ---
player.on('pause', ()=>{
  try {
    const sk = player.seekable();
    if (!sk || !sk.length) return;
    const nowU = Math.floor(Date.now()/1000);
    const end = sk.end(0);
    const secondsBehind = Math.max(0, end - player.currentTime());
    __pausedUnix = nowU - currentDvrOffset - secondsBehind;
  } catch(_){}
});

player.on('play', ()=>{
  try{
    if (!__pausedUnix) return;
    const nowU = Math.floor(Date.now()/1000);
    const elapsed = nowU - __pausedUnix;
    const MAX_SEC = DVR_DAYS * 24 * 3600;
    if (elapsed < 0 || elapsed > MAX_SEC){ __pausedUnix = null; return; }

    const win = (typeof player.__rsCurrentWindowSec === 'number' && player.__rsCurrentWindowSec > 0)
      ? player.__rsCurrentWindowSec
      : CHUNK_SEC;
    const targetOffset = Math.floor(elapsed/win) * win;
    if (targetOffset === currentDvrOffset){
      const sk = player.seekable(); if (!sk || !sk.length){ __pausedUnix = null; return; }
      const end = sk.end(0);
      const nowMinusOffset = nowU - currentDvrOffset;
      const secondsBehindEnd = nowMinusOffset - __pausedUnix;
      const t = Math.max(0, end - secondsBehindEnd);
      try{ player.currentTime(t); }catch(_){}
      __pausedUnix = null;
      return;
    }
    jumpToUnix(__pausedUnix, false);
  } finally {
    __pausedUnix = null;
  }
});

