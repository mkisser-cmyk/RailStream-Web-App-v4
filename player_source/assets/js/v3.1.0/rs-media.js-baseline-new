let camSel, daySel, blockSel, timeInput, goBtn;

function setHHMM(h, m){
  const hh = pad(Math.min(23, Math.max(0, parseInt(h||0,10))));
  const mm = pad(Math.min(59, Math.max(0, parseInt(m||0,10))));
  if (timeInput) timeInput.value = `${hh}:${mm}`;
}

function getHHMM(){
  if (!timeInput || !timeInput.value) return {h:0,m:0};
  const [H, M] = String(timeInput.value).split(':');
  const h = Math.min(23, Math.max(0, parseInt(H||'0',10) || 0));
  const m = Math.min(59, Math.max(0, parseInt(M||'0',10) || 0));
  return {h, m};
}

// --- Sync toolbar selectors to an absolute wall-unix time ---
function __rsSyncSelectorsToUnix(unix){
  try{
    if (!daySel || !blockSel || !timeInput) return;
    const nowU = Math.floor(Date.now()/1000);
    let delta = Math.max(0, nowU - unix);               // seconds behind "now"
    if (delta > MAX_WINDOW_SEC) delta = MAX_WINDOW_SEC; // clamp to window

    const dayIdx = Math.floor(delta / 86400);
    const remDay = delta % 86400;
    const blockIdx = Math.floor(remDay / CHUNK_SEC);

    const d = new Date(unix * 1000);
    const H = String(d.getHours()).padStart(2,'0');
    const M = String(d.getMinutes()).padStart(2,'0');

    const maxDay = Math.max(0, DVR_DAYS - 1);
    const perDay = Math.max(1, Math.floor(24 / CHUNK_HOURS));
    daySel.value   = String(Math.min(dayIdx, maxDay));
    blockSel.value = String(Math.min(blockIdx, perDay-1));
    timeInput.value = `${H}:${M}`;
  }catch(_){}
}

