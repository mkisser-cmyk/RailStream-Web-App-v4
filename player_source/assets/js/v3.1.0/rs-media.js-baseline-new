      const finePointer = matchMedia && matchMedia('(pointer:fine)').matches;
      if (isMobileUA || !finePointer) return;
    }catch(_){}

    const wrap = pv && pv.el && pv.el();
    if (!wrap) return;
    let menu = null;
    const build = ()=>{
      if (menu) return menu;
      menu = document.createElement('div'); menu.className='rs-menu';
      const add = (label, right, fn, cls='')=>{
        const it=document.createElement('div'); it.className='item'+(cls?` ${cls}`:'');
        const l=document.createElement('span'); l.textContent=label;
        const r=document.createElement('span'); r.textContent=right||''; r.style.opacity=.7;
        it.append(l,r); if (fn) it.onclick=()=>{ hide(); fn(); };
        menu.appendChild(it);
      };
      add('Keyboard shortcuts', 'Shift+/', ()=> window.__rsToggleHelp());
      add('Toggle Dev Tools', 'Shift+D', ()=> window.__rsOpenDiagPanel());
      const sep=document.createElement('div'); sep.style.cssText='height:1px;background:rgba(255,255,255,.12)'; menu.appendChild(sep);
      add(`Version ${(window.RS_VERSION||'DEV')}`, '', null, 'muted');
      document.body.appendChild(menu);
      return menu;
    };
    const show = (x,y)=>{
      const m=build(); m.style.display='block';
      const vw=innerWidth, vh=innerHeight, r=m.getBoundingClientRect();
      m.style.left = Math.min(x, vw-r.width-8)+'px';
      m.style.top  = Math.min(y, vh-r.height-8)+'px';
      const once = ()=>{ hide(); document.removeEventListener('click', once); };
      setTimeout(()=> document.addEventListener('click', once), 0);
    };
    const hide = ()=>{ if (menu) menu.style.display='none'; };
    wrap.addEventListener('contextmenu', (e)=>{ e.preventDefault(); show(e.clientX, e.clientY); });
  })();

  // Help modal
  (function(){
    if (document.getElementById('rs-help')) return;
    const help = document.createElement('div'); help.id='rs-help';
    help.innerHTML = `
      <div class="card">
        <div style="display:flex;align-items:center;gap:10px">
          <h3 style="margin:0;font:600 16px/1.2 system-ui">RailStream Shortcuts</h3>
          <button id="rs-help-close" class="rs-btn" style="margin-left:auto">Close</button>
        </div>
        <div style="display:grid;grid-template-columns: 1fr 1fr;gap:10px;margin-top:12px;font:14px/1.4 system-ui">
          <div><code>←</code> — Back 10s</div>
          <div><code>→</code> — Forward 10s</div>
          <div><code>Shift + ←</code> — Back 30s</div>
          <div><code>Shift + →</code> — Forward 30s</div>
          <div><code>Shift + D</code> — Toggle Dev Tools</div>
          <div><code>Shift + /</code> — Show this help</div>
          <div style="grid-column:1/-1;opacity:.8">Note: Shortcuts are enabled on desktop only.</div>
        </div>
      </div>`;
    document.body.appendChild(help);
    help.querySelector('#rs-help-close').onclick = ()=> { help.style.display='none'; };
  })();
})();

// ===== Admin export hooks (only active when adminTools=1) =====
(function(){
  try {
    const params = new URLSearchParams(window.location.search);
    if (params.get('adminTools') !== '1') return;

    if (!window.player || typeof __rsCurrentUnixFromTime !== 'function') return;

    let PARENT_ORIGIN = '*';
    try{
      if (C.parentOrigin) PARENT_ORIGIN = String(C.parentOrigin);
      else if (document.referrer) PARENT_ORIGIN = new URL(document.referrer).origin;
    }catch(_){ PARENT_ORIGIN = '*'; }

    player.on('timeupdate', function(){
      try {
        const u = __rsCurrentUnixFromTime();
        if (!u || !Number.isFinite(u)) return;

        window.parent.postMessage(
          { type: 'RS_PLAYHEAD_TIME', unix_ts: u },
          PARENT_ORIGIN
        );
      } catch(_) {}
    });

    window.addEventListener('message', function(e){
      try {
        if (PARENT_ORIGIN !== '*' && e.origin !== PARENT_ORIGIN) return;

        const data = e.data || {};
        if (data.type === 'RS_SEEK_TO' && typeof data.unix_ts === 'number') {
          if (typeof jumpToUnix === 'function') {
            jumpToUnix(Math.floor(data.unix_ts), false);
          }
        }
      } catch(_) {}
    });

  } catch(_) {}
})();

/* ============================================================
 * RS v3.x glue — restores behaviors previously inline in rs-media.php
 * ============================================================ */
(function RS_GLUE_V3X(){
  'use strict';

  const $ = (id) => document.getElementById(id);
  const safe = (fn) => { try { fn(); } catch(_){} };
  const onReady = (fn) => {
    if (document.readyState !== 'loading') fn();
    else document.addEventListener('DOMContentLoaded', fn);
  };
  const isTouch = () => ('ontouchstart' in window) || (navigator.maxTouchPoints > 0);

  // ---- 1) Toolbar auto-hide + hotzone ----
  const PORTRAIT_BP = 940;
  const HIDE_DELAY  = 2600;
  const HOTZONE_H   = 16;

  let tbar = null;
  let collapseTimer = null;

  function shouldCollapse(){ return innerWidth <= PORTRAIT_BP; }

  function collapseToolbar(){
    if (!tbar) tbar = $('rs-toolbar');
    if (!tbar) return;
    if (!shouldCollapse()){
      tbar.classList.remove('collapsed');
      return;
    }
    tbar.classList.add('collapsed');
  }

  function revealToolbar(ms){
    if (!tbar) tbar = $('rs-toolbar');
    if (!tbar) return;

    tbar.classList.remove('collapsed');

    if (collapseTimer){ clearTimeout(collapseTimer); collapseTimer = null; }
    if (shouldCollapse()){
      collapseTimer = setTimeout(collapseToolbar, ms || HIDE_DELAY);
    }
  }

  function bindHotzone(){
    let hz = $('rs-toolbar-hotzone');
    if (!hz){
      hz = document.createElement('div');
      hz.id = 'rs-toolbar-hotzone';
      hz.setAttribute('aria-hidden', 'true');
      document.body.appendChild(hz);
    }

    const handler = (e) => safe(() => {
      const y = (e.touches && e.touches[0]) ? e.touches[0].clientY : (e.clientY || 0);
      if (y <= (HOTZONE_H + 2)) revealToolbar(2200);
    });

    ['mousemove','pointermove','touchstart','touchmove'].forEach((tp) => {
      addEventListener(tp, handler, { passive: true });
    });
  }

  function initToolbarAutoHide(){
    tbar = $('rs-toolbar');
    if (!tbar) return;

    bindHotzone();

    if (shouldCollapse()) tbar.classList.add('collapsed');
    else tbar.classList.remove('collapsed');

    tbar.addEventListener('change', () => revealToolbar(1200), true);
    tbar.addEventListener('click', (e) => {
      const t = e.target;
      if (!t) return;
      if (t.id === 'liveBtn' || (t.classList && t.classList.contains('rs-btn-go')) || t.tagName === 'SELECT'){
        revealToolbar(1000);
      }
    }, true);

    addEventListener('resize', () => {
      if (shouldCollapse()) collapseToolbar();
      else revealToolbar(0);
    }, { passive:true });

    addEventListener('orientationchange', () => {
      setTimeout(() => {
        if (shouldCollapse()) collapseToolbar();
        else revealToolbar(0);
      }, 0);
    }, { passive:true });
  }

  // ---- 2) Fullscreen thumbnail forwarding ----
  function bindThumbsIn(el){
    safe(() => {
      if (!el) return;
      const holders = el.querySelectorAll('.vjs-progress-holder, .vjs-progress-control, .vjs-slider');
      if (!holders || !holders.length) return;

      const root = (window.player && player.el) ? player.el() : document;

      function forwardMove(x,y){
        safe(() => root.dispatchEvent(new MouseEvent('mousemove', { bubbles:true, clientX:x, clientY:y })));
      }

      holders.forEach((h) => {
        if (h.__rsThumbBound) return;
        h.__rsThumbBound = true;

        h.addEventListener('pointermove', (e) => forwardMove(e.clientX, e.clientY), { passive:true });
        h.addEventListener('touchmove', (e) => {
          const t = (e.touches && e.touches[0]) ? e.touches[0] : null;
          if (t) forwardMove(t.clientX, t.clientY);
        }, { passive:true });
      });
    });
  }

  function bindThumbsFullscreen(){
    let tries = 0;
    (function tick(){
      const fe = document.fullscreenElement || (window.player && player.el && player.el());
      bindThumbsIn(fe || document);
      if (tries++ < 10) setTimeout(tick, 120);
    })();
  }

  // ---- 3) Touch long-press context menu block (only inside player) ----
  function initLongPressBlock(){
    if (!isTouch()) return;

    function withinPlayer(el){
      try{
        const root = $('cam_player');
        return !!(root && (el === root || (el && root.contains(el))));
      }catch(_){ return false; }
    }

    function hardBlock(e){
      if (!withinPlayer(e.target)) return;
      e.preventDefault();
      e.stopImmediatePropagation();
      return false;
    }

    addEventListener('contextmenu', hardBlock, { capture:true });
    document.addEventListener('contextmenu', hardBlock, { capture:true });

    const root = $('cam_player');
    if (root){
      root.oncontextmenu = (e)=>{ e.preventDefault(); return false; };
      const v = root.querySelector('video');
      if (v) v.oncontextmenu = (e)=>{ e.preventDefault(); return false; };
    }
  }

  // ---- 4) Aspect sizing (fluid padding from metadata) ----
  function applyAspectFromMeta(){
    safe(() => {
      const root = $('cam_player');
      if (!root) return;
      const v = root.querySelector('video');
      if (!v) return;

      const w = v.videoWidth || 0;
      const h = v.videoHeight || 0;
      if (!w || !h) return;

      root.classList.add('vjs-fluid');
      root.style.paddingTop = (((h / w) * 100).toFixed(6)) + '%';
    });
  }

  function initAspectFallback(){
    safe(() => {
      const root = $('cam_player');
      if (!root) return;
      root.classList.add('vjs-fluid');
      root.style.paddingTop = '56.25%';
      applyAspectFromMeta();
    });
  }

  // ---- 5) iframe height postMessage to parent ----
  function initIframeHeightPosting(){
    const POST_TYPE = 'rs:height';

    function docHeight(){
      const b=document.body, d=document.documentElement;
      const app = $('rs-app') || $('rs-shell') || document.body;
      const appH = app ? Math.ceil(app.getBoundingClientRect().height) : 0;
      return Math.max(appH, b.scrollHeight, d.scrollHeight, b.offsetHeight, d.offsetHeight, b.clientHeight, d.clientHeight);
    }

    let t;
    function post(immediate){
      clearTimeout(t);
      const run = () => safe(() => {
        if (window.parent && window.parent !== window){
          window.parent.postMessage({ type: POST_TYPE, height: docHeight() }, '*');
        }
      });
      if (immediate) run();
      else { t=setTimeout(run,50); setTimeout(run,300); }
    }

    onReady(() => post(true));
    addEventListener('load', () => post(true));
    addEventListener('resize', () => post(false), { passive:true });

    const toolbar = $('rs-toolbar');
    if (toolbar && window.MutationObserver){
      new MutationObserver(() => post(false))
        .observe(toolbar, { attributes:true, attributeFilter:['class','style'] });

      ['transitionend','animationend'].forEach((evt) => {
        toolbar.addEventListener(evt, () => post(false), { passive:true });
      });
    }

    if (window.ResizeObserver){
      safe(() => new ResizeObserver(() => post(false)).observe(document.documentElement));
    }

    safe(() => {
      if (!(window.player && player.on)) return;
      [
        'loadedmetadata','loadeddata','canplay','play','pause',
        'seeking','seeked','resize','fullscreenchange','useractive','userinactive'
      ].forEach((ev) => player.on(ev, () => post(false)));
    });
  }

  onReady(() => {
    initToolbarAutoHide();
    initAspectFallback();
    initLongPressBlock();
    initIframeHeightPosting();

    safe(() => {
      if (window.player && player.on){
        player.on('fullscreenchange', () => {
          setTimeout(bindThumbsFullscreen, 0);
          setTimeout(applyAspectFromMeta, 0);
        });
        player.one('loadedmetadata', () => setTimeout(applyAspectFromMeta, 0));
        player.ready(() => setTimeout(bindThumbsFullscreen, 0));
      }
    });
  });
})();