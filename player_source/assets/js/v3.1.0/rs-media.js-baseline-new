  reviewPill.onclick = async ()=>{
    OPS.mode = 'review';
    syncPills();
    syncReviewCtl();
    await openReviewSetup();
  };

  blockBtn.onclick = ()=> openReviewSetup();

  prevBtn.onclick = async ()=>{
    try{
      const r = await rsGetDvrRangeCached();
      const nowU = r.nowUnix;
      if (!OPS.cursorUnix) OPS.cursorUnix = nowU - OPS.blockSec;
      let target = OPS.cursorUnix - OPS.blockSec;
      if (target < r.oldestUnix) target = r.oldestUnix;
      OPS.cursorUnix = target;
      await safeSeekUnix(target);
    }catch(_){}
  };

  nextBtn.onclick = async ()=>{
    try{
      const r = await rsGetDvrRangeCached();
      const nowU = r.nowUnix;
      if (!OPS.cursorUnix) OPS.cursorUnix = nowU - OPS.blockSec;
      let target = OPS.cursorUnix + OPS.blockSec;
      // If target is at/after live edge, switch to live ops
      if (target >= (r.newestUnix - 5)){
        OPS.mode = 'live';
        OPS.cursorUnix = null;
        syncPills(); syncReviewCtl();
        closeOverlay();
        await setChunk(0, {autoplay:true});
        return;
      }
      if (target < r.oldestUnix) target = r.oldestUnix;
      OPS.cursorUnix = target;
      await safeSeekUnix(target);
    }catch(_){}
  };
}

