(function rsInstallDesktopKeys(){
  try{
    const isMobileUA = /Android|iPhone|iPad|iPod|Mobile/i.test(navigator.userAgent);
    const finePointer = matchMedia && matchMedia('(pointer:fine)').matches;
    if (isMobileUA || !finePointer) return;
  }catch(_){}

  function isTypingTarget(el){
    if (!el) return false;
    const tag = el.tagName;
    if (!tag) return false;
    if (/INPUT|TEXTAREA|SELECT/.test(tag)) return true;
    if (el.isContentEditable) return true;
    return false;
  }

  document.addEventListener('keydown', (e)=>{
    const tgt = e.target;
    if (isTypingTarget(tgt)) return;

    if (e.shiftKey && e.key === 'ArrowLeft'){ e.preventDefault(); __rsSeekBy(-30); return; }
    if (e.shiftKey && e.key === 'ArrowRight'){ e.preventDefault(); __rsSeekBy(30); return; }

    if (!e.shiftKey && e.key === 'ArrowLeft'){ e.preventDefault(); __rsSeekBy(-10); return; }
    if (!e.shiftKey && e.key === 'ArrowRight'){ e.preventDefault(); __rsSeekBy(10); return; }

