        t.style.cssText = 'position:fixed;left:50%;bottom:38px;transform:translateX(-50%);z-index:2147483000;background:rgba(20,24,28,.92);color:#fff;border:1px solid rgba(255,255,255,.12);border-radius:10px;padding:8px 12px;font:600 13px system-ui, -apple-system;box-shadow:0 8px 24px rgba(0,0,0,.35)';
